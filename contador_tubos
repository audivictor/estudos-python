        "import cv2\n",
        "import numpy as np\n",
        "from scipy.spatial.distance import cdist\n",
        "from google.colab import files\n",
        "import os\n",
        "\n",
        "def nms_pontos(pontos, dist_min=55):\n",
        "    if len(pontos) == 0:\n",
        "        return pontos\n",
        "    pts = np.array(pontos, dtype=float)\n",
        "    D   = cdist(pts, pts)\n",
        "    np.fill_diagonal(D, np.inf)\n",
        "    mantidos = [True] * len(pts)\n",
        "    for i in range(len(pts)):\n",
        "        if not mantidos[i]:\n",
        "            continue\n",
        "        for j in range(i + 1, len(pts)):\n",
        "            if mantidos[j] and D[i, j] < dist_min:\n",
        "                mantidos[j] = False\n",
        "    return [p for p, m in zip(pontos, mantidos) if m]\n",
        "\n",
        "for f in os.listdir('/content'):\n",
        "    if f.endswith(('.jpg', '.jpeg', '.png')):\n",
        "        os.remove(f'/content/{f}')\n",
        "\n",
        "uploaded  = files.upload()\n",
        "filename  = list(uploaded.keys())[0]\n",
        "\n",
        "img  = cv2.imread(filename)\n",
        "vis  = img.copy()\n",
        "gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n",
        "hsv  = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)\n",
        "h_img, w_img = gray.shape\n",
        "\n",
        "# ── 1. HSV restrito: saturação ≥ 205 elimina ferrugem ────────────────────────\n",
        "mask = (\n",
        "    cv2.inRange(hsv, np.array([0,  205, 140]), np.array([8,  255, 255])) |\n",
        "    cv2.inRange(hsv, np.array([8,  200, 140]), np.array([20, 255, 255])) |\n",
        "    cv2.inRange(hsv, np.array([168,200, 100]), np.array([180,255, 255]))\n",
        ")\n",
        "k = np.ones((3, 3), np.uint8)\n",
        "mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN, k)\n",
        "mask = cv2.dilate(mask, k, iterations=1)\n",
        "\n",
        "contornos, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n",
        "\n",
        "pontos_raw = []\n",
        "for cnt in contornos:\n",
        "    area = cv2.contourArea(cnt)\n",
        "    if not (8 < area < 500):\n",
        "        continue\n",
        "\n",
        "    # ── 2. Circularidade: tinta = compacta; ferrugem = irregular ─────────────\n",
        "    peri = cv2.arcLength(cnt, True)\n",
        "    if peri == 0:\n",
        "        continue\n",
        "    if 4 * np.pi * area / (peri ** 2) < 0.35:\n",
        "        continue\n",
        "\n",
        "    M = cv2.moments(cnt)\n",
        "    if M['m00'] == 0:\n",
        "        continue\n",
        "    px = int(M['m10'] / M['m00'])\n",
        "    py = int(M['m01'] / M['m00'])\n",
        "\n",
        "    # ── 3. Contexto: bore do tubo é escuro; flange metálica é clara ──────────\n",
        "    # Checa uma coroa circular ao redor do ponto (exclui o próprio dot)\n",
        "    r_in, r_out = 8, 28\n",
        "    y0 = max(0, py - r_out); y1 = min(h_img, py + r_out)\n",
        "    x0 = max(0, px - r_out); x1 = min(w_img, px + r_out)\n",
        "    roi_g = gray[y0:y1, x0:x1]\n",
        "\n",
        "    # máscara da coroa dentro do roi\n",
        "    cy_r = py - y0; cx_r = px - x0\n",
        "    corona = np.zeros_like(roi_g)\n",
        "    cv2.circle(corona, (cx_r, cy_r), min(r_out, corona.shape[0]//2), 255, -1)\n",
        "    cv2.circle(corona, (cx_r, cy_r), r_in,  0,   -1)\n",
        "\n",
        "    pixeis = roi_g[corona > 0]\n",
        "    if pixeis.size < 20:\n",
        "        continue\n",
        "    if np.mean(pixeis) > 115:          # claro = flange, não bore\n",
        "        continue\n",
        "\n",
        "    pontos_raw.append((px, py))\n",
        "\n",
        "pontos = nms_pontos(pontos_raw, dist_min=55)\n",
        "\n",
        "for (px, py) in pontos:\n",
        "    cv2.circle(vis, (px, py), 28, (0, 255, 0), 2)\n",
        "    cv2.circle(vis, (px, py),  4, (0, 255, 0), -1)\n",
        "\n",
        "cv2.putText(vis, f\"{len(pontos)} tubos\", (30, 70),\n",
        "            cv2.FONT_HERSHEY_SIMPLEX, 2.2, (0, 255, 0), 3)\n",
        "\n",
        "print(f\"Candidatos brutos : {len(pontos_raw)}\")\n",
        "print(f\"Após NMS + filtros: {len(pontos)} tubos\")\n",
        "\n",
        "cv2.imwrite(\"resultado.jpg\", vis)\n",
        "files.download(\"resultado.jpg\")"
      ]
